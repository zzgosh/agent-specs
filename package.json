{
  "name": "agent-spec",
  "version": "0.1.5",
  "description": "CLI for managing AGENTS.md files",
  "type": "module",
  "bin": {
    "agent-spec": "bin/cli.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/cli.mjs"
    }
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "dev": "tsx src/cli.ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.2",
    "unbuild": "^3.5.0"
  },
  "keywords": [
    "agent-spec",
    "agents",
    "ai",
    "cli",
    "rules",
    "symlink"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zzgosh/agent-spec.git"
  },
  "bugs": {
    "url": "https://github.com/zzgosh/agent-spec/issues"
  },
  "license": "MIT"
}
